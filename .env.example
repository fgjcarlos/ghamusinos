# Entorno de ejecución: development | production
ENV=development

# Puerto TCP del servidor HTTP
PORT=8080

# ─── Base de datos ─────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD no tiene valor por defecto: debe definirse explícitamente.
# En staging/prod genera contraseñas aleatorias (p. ej. openssl rand -base64 32).
# Si la contraseña contiene caracteres reservados de URL (@, /, :, #), define
# DATABASE_URL manualmente con el valor URL-encodeado.
POSTGRES_USER=ghamusinos
POSTGRES_PASSWORD=
POSTGRES_DB=ghamusinos

# Cadena de conexión a PostgreSQL (OBLIGATORIA)
DATABASE_URL=postgres://${POSTGRES_USER}:***@localhost:5432/${POSTGRES_DB}?sslmode=disable

# ─── Pool de PostgreSQL (pgxpool) ──────────────────────────────────────────
# Sobrescriben los valores por defecto de db.DefaultPoolConfig().
# Formato de duración Go: "5s", "1h30m", "500ms", etc.

# Tamaño máximo del pool. Default 20.
DB_POOL_MAX_CONNS=20
# Tamaño mínimo (warm pool). Default 2. Debe ser 0 ≤ n ≤ DB_POOL_MAX_CONNS.
DB_POOL_MIN_CONNS=2
# Tiempo máximo de vida de una conexión. Default 1h.
DB_POOL_MAX_CONN_LIFETIME=1h
# Tiempo máximo de inactividad de una conexión. Default 30m.
DB_POOL_MAX_CONN_IDLE_TIME=30m
# Timeout para establecer una conexión TCP nueva. Default 5s.
# Recomendado SIEMPRE > 0 para evitar arranques colgados.
DB_POOL_CONNECT_TIMEOUT=5s
# Cadencia del health check de conexiones idle. Default 1m.
DB_POOL_HEALTH_CHECK_PERIOD=1m
