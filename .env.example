# Entorno de ejecución: development | production
ENV=development

# Puerto TCP del servidor HTTP
PORT=8080

# ─── Base de datos ─────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD no tiene valor por defecto: debe definirse explícitamente.
# En staging/prod genera contraseñas aleatorias (p. ej. openssl rand -base64 32).
# Si la contraseña contiene caracteres reservados de URL (@, /, :, #), define
# DATABASE_URL manualmente con el valor URL-encodeado.
POSTGRES_USER=ghamusinos
POSTGRES_PASSWORD=
POSTGRES_DB=ghamusinos

# Cadena de conexión a PostgreSQL (OBLIGATORIA)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?sslmode=disable
